{
  "name": "typescript-backend-best-practice",
  "version": "1.0.0",
  "description": "a backend designed using best practices",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --poll src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --watchAll --no-cach --detectOpenHandles",
    "postgres": "docker run --name postgres14 -p 5432:5432 -e POSTGRES_USER=root -e POSTGRES_PASSWORD=secret -d postgres:14-alpine",
    "createdb": "docker exec -it postgres14 createdb --username=root --owner=root typescript-backend-best-practice",
    "postgres:stop": "docker stop postgres14"
  },
  "repository": {
    "type": "git",
    "url": "github.com/deanrtaylor1/typescript-backend-best-practice"
  },
  "keywords": [
    "typescript"
  ],
  "author": "Dean Taylor",
  "license": "ISC",
  "dependencies": {
    "@types/cli-color": "^2.0.2",
    "@types/helmet": "^4.0.0",
    "@types/pg": "^8.6.6",
    "chalk": "^5.2.0",
    "cli-color": "^2.0.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-validator": "^6.15.0",
    "helmet": "^6.0.1",
    "morgan": "^1.10.0",
    "pg": "^8.10.0",
    "typescript": "^5.0.2"
  },
  "devDependencies": {
    "@types/chalk": "^2.2.0",
    "@types/morgan": "^1.9.4",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.0.5",
    "ts-node-dev": "^2.0.0"
  }
}
